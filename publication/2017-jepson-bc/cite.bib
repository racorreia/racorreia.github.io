@article{JEPSON2017183,
title = "Protected area asset stewardship",
journal = "Biological Conservation",
volume = "212",
pages = "183 - 190",
year = "2017",
issn = "0006-3207",
doi = "https://doi.org/10.1016/j.biocon.2017.03.032",
url = "http://www.sciencedirect.com/science/article/pii/S0006320716304979",
author = "Paul R. Jepson and Ben Caldecott and Suzanne F. Schmitt and Sergio H.C. Carvalho and Ricardo A. Correia and Norah Gamarra and Chiara Bragagnolo and Ana C.M. Malhado and Richard J. Ladle",
keywords = "Protected areas, Conservation policy, Natural assets, Natural capital, Conservation values",
abstract = "Protected areas (PAs) are the main strategy to conserve natural values and reduce biodiversity loss. However, with increasing global food requirements, using land for protecting landscapes and species is becoming increasingly difficult to justify. Here, we argue that framing PAs as spatial assets provides an ideal platform for generating investment and increasing their political/cultural resilience. Specifically, we define and characterize PAs in terms of their biophysical, human, infrastructure, institutional and cultural assets, making explicit the forms of value they create and for whom, and identifying types of investment needed to generate value in the medium and long term. These assets can be protected, managed and/or invested in to generate (monetizable and non-monetizable) forms of value. They can also be at risk from a variety of factors. Building on contemporary conservation policy, our asset framework provides an innovative approach to the development and management of PAs in the 21st Century."
}