
@article{gilbert_are_2016,
	title = {Are white storks addicted to junk food? {Impacts} of landfill use on the movement and behaviour of resident white storks ({Ciconia} ciconia) from a partially migratory population},
	volume = {4},
	copyright = {All rights reserved},
	issn = {2051-3933},
	shorttitle = {Are white storks addicted to junk food?},
	url = {https://doi.org/10.1186/s40462-016-0070-0},
	doi = {10.1186/s40462-016-0070-0},
	abstract = {The migratory patterns of animals are changing in response to global environmental change with many species forming resident populations in areas where they were once migratory. The white stork (Ciconia ciconia) was wholly migratory in Europe but recently guaranteed, year-round food from landfill sites has facilitated the establishment of resident populations in Iberia. In this study 17 resident white storks were fitted with GPS/GSM data loggers (including accelerometer) and tracked for 9.1 ± 3.7 months to quantify the extent and consistency of landfill attendance by individuals during the non-breeding and breeding seasons and to assess the influence of landfill use on daily distances travelled, percentage of GPS fixes spent foraging and non-landfill foraging ranges.},
	number = {1},
	urldate = {2020-03-01},
	journal = {Movement Ecology},
	author = {Gilbert, Nathalie I. and Correia, Ricardo A. and Silva, João Paulo and Pacheco, Carlos and Catry, Inês and Atkinson, Philip W. and Gill, Jenny A. and Franco, Aldina M. A.},
	month = mar,
	year = {2016},
	note = {ZSCC: NoCitationData[s0]},
	pages = {7},
	file = {Gilbert et al_2016_Are white storks addicted to junk food.pdf:/home/rcorreia/snap/zotero-snap/common/Zotero/storage/AV9JVGQ4/Gilbert et al_2016_Are white storks addicted to junk food.pdf:application/pdf}
}
